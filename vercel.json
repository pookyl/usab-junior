{
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60,
      "includeFiles": "data/**"
    }
  },
  "rewrites": [
    { "source": "/a/script.js", "destination": "/_vercel/insights/script.js" },
    { "source": "/a/:path*", "destination": "/_vercel/insights/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
