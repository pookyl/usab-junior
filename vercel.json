{
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    },
    "api/*rankings.js": {
      "includeFiles": "data/{rankings-cache.json,rankings-*.json}"
    },
    "api/*players.js": {
      "includeFiles": "data/{rankings-cache.json,rankings-*.json}"
    },
    "api/*dates.js": {
      "includeFiles": "data/rankings-*.json"
    },
    "api/*directory.js": {
      "includeFiles": "data/player-directory.json"
    },
    "api/player/**/*.js": {
      "includeFiles": "data/{rankings-cache.json,player-ranking-trends.json}"
    },
    "api/*tournaments.js": {
      "includeFiles": "data/tournaments-*.json"
    },
    "api/tournaments/**/*.js": {
      "includeFiles": "data/tournament-cache/**"
    }
  },
  "rewrites": [
    { "source": "/((?!api/|a/).*)", "destination": "/index.html" }
  ]
}
