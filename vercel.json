{
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    },
    "api/rankings.js": {
      "includeFiles": [
        "data/rankings-cache.json",
        "data/rankings-*.json"
      ]
    },
    "api/all-players.js": {
      "includeFiles": [
        "data/rankings-cache.json",
        "data/rankings-*.json"
      ]
    },
    "api/cached-dates.js": {
      "includeFiles": "data/rankings-*.json"
    },
    "api/player-directory.js": {
      "includeFiles": "data/player-directory.json"
    },
    "api/player/[id].js": {
      "includeFiles": "data/rankings-cache.json"
    },
    "api/player/[id]/[action].js": {
      "includeFiles": [
        "data/rankings-cache.json",
        "data/player-ranking-trends.json"
      ]
    },
    "api/tournaments.js": {
      "includeFiles": "data/tournaments-*.json"
    },
    "api/tournaments/[tswId]/[action].js": {
      "includeFiles": "data/tournament-cache/**"
    }
  },
  "rewrites": [
    { "source": "/((?!api/|a/).*)", "destination": "/index.html" }
  ]
}
